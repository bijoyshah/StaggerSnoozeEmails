{
  "manifest_version": 3,
  "name": "Gmail Stagger Snooze",
  "version": "1.0",
  "description": "Snooze selected emails in staggered increments",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://mail.google.com/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}